<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="byte_leg">

  <xacro:arg name="controllers_config" default="$(find byte_leg_control)/config/controllers.yaml"/>
  <xacro:arg name="use_sim" default="true"/>

  <xacro:property name="rig_height"    value="1.0"/>
  <xacro:property name="thigh_length"  value="0.30"/>
  <xacro:property name="shank_length"  value="0.30"/>
  <xacro:property name="rod_radius"    value="0.0075"/>
  <xacro:property name="foot_radius"   value="0.02"/>

  <xacro:property name="motor_mass"    value="0.43"/>
  <xacro:property name="rod_mass"      value="0.05"/>
  <xacro:property name="foot_mass"     value="0.024"/>

  <xacro:property name="slide_lower"   value="-0.38"/>
  <xacro:property name="slide_upper"   value="0.20"/>

  <xacro:macro name="motor_inertial" params="mass">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${mass}"/>
      <inertia ixx="${mass*(0.060*0.060 + 0.040*0.040)/12.0}"
               iyy="${mass*(0.060*0.060 + 0.040*0.040)/12.0}"
               izz="${mass*(0.060*0.060 + 0.060*0.060)/12.0}"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="rod_inertial" params="mass length radius">
    <inertial>
      <origin xyz="0 0 ${-length/2.0}" rpy="0 0 0"/>
      <mass value="${mass}"/>
      <inertia ixx="${mass*(3.0*radius*radius + length*length)/12.0}"
               iyy="${mass*(3.0*radius*radius + length*length)/12.0}"
               izz="${mass*radius*radius/2.0}"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="sphere_inertial" params="mass radius">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${mass}"/>
      <inertia ixx="${2.0*mass*radius*radius/5.0}"
               iyy="${2.0*mass*radius*radius/5.0}"
               izz="${2.0*mass*radius*radius/5.0}"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </xacro:macro>

  <link name="world"/>

  <link name="rig_frame">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.1 0.3 0.02"/></geometry>
      <material name="rig_grey"><color rgba="0.3 0.3 0.3 1"/></material>
    </visual>
  </link>
  <joint name="rig_mount" type="fixed">
    <parent link="world"/>
    <child  link="rig_frame"/>
    <origin xyz="0 0 ${rig_height}" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <xacro:motor_inertial mass="${motor_mass}"/>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.06 0.06 0.04"/></geometry>
      <material name="abduct_red"><color rgba="0.8 0.2 0.2 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.06 0.06 0.04"/></geometry>
    </collision>
  </link>
  <joint name="base_slide" type="prismatic">
    <parent link="rig_frame"/>
    <child  link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${slide_lower}" upper="${slide_upper}" effort="200" velocity="2.0"/>
    <dynamics damping="5.0" friction="1.0"/>
  </joint>

  <link name="hip_abduct_link">
    <xacro:motor_inertial mass="${motor_mass}"/>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.06 0.06 0.04"/></geometry>
      <material name="pitch_green"><color rgba="0.2 0.7 0.2 1"/></material>
    </visual>
  </link>
  <joint name="hip_abduct" type="revolute">
    <parent link="base_link"/>
    <child  link="hip_abduct_link"/>
    <origin xyz="0 0 -0.04" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="${-pi}" upper="${pi}" effort="20" velocity="20"/>
    <dynamics damping="0.05" friction="0.02"/>
  </joint>

  <link name="thigh_link">
    <xacro:rod_inertial mass="${rod_mass}" length="${thigh_length}" radius="${rod_radius}"/>
    <visual>
      <origin xyz="0 0 ${-thigh_length/2.0}" rpy="0 0 0"/>
      <geometry><cylinder radius="${rod_radius}" length="${thigh_length}"/></geometry>
      <material name="carbon_black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 ${-thigh_length/2.0}" rpy="0 0 0"/>
      <geometry><cylinder radius="${rod_radius}" length="${thigh_length}"/></geometry>
    </collision>
  </link>
  <joint name="hip_pitch" type="revolute">
    <parent link="hip_abduct_link"/>
    <child  link="thigh_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${-pi}" upper="${pi}" effort="20" velocity="20"/>
    <dynamics damping="0.05" friction="0.02"/>
  </joint>

  <link name="knee_link">
    <xacro:motor_inertial mass="${motor_mass}"/>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.05 0.05 0.03"/></geometry>
      <material name="knee_blue"><color rgba="0.2 0.3 0.8 1"/></material>
    </visual>
  </link>
  <joint name="knee_mount" type="fixed">
    <parent link="thigh_link"/>
    <child  link="knee_link"/>
    <origin xyz="0 0 ${-thigh_length}" rpy="0 0 0"/>
  </joint>

  <link name="shank_link">
    <xacro:rod_inertial mass="${rod_mass}" length="${shank_length}" radius="${rod_radius}"/>
    <visual>
      <origin xyz="0 0 ${-shank_length/2.0}" rpy="0 0 0"/>
      <geometry><cylinder radius="${rod_radius}" length="${shank_length}"/></geometry>
      <material name="carbon_black"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${-shank_length/2.0}" rpy="0 0 0"/>
      <geometry><cylinder radius="${rod_radius}" length="${shank_length}"/></geometry>
    </collision>
  </link>
  <joint name="knee" type="revolute">
    <parent link="knee_link"/>
    <child  link="shank_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${-pi}" upper="${pi}" effort="20" velocity="20"/>
    <dynamics damping="0.05" friction="0.02"/>
  </joint>

  <link name="foot_link">
    <xacro:sphere_inertial mass="${foot_mass}" radius="${foot_radius}"/>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="${foot_radius}"/></geometry>
      <material name="ball_yellow"><color rgba="0.9 0.9 0.2 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="${foot_radius}"/></geometry>
      <surface>
        <friction><ode><mu>1.2</mu><mu2>1.2</mu2></ode></friction>
      </surface>
    </collision>
  </link>
  <joint name="foot_fixed" type="fixed">
    <parent link="shank_link"/>
    <child  link="foot_link"/>
    <origin xyz="0 0 ${-shank_length}" rpy="0 0 0"/>
  </joint>

  <ros2_control name="byte_leg_system" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
      <param name="position_proportional_gain">200.0</param>
    </hardware>
    <joint name="hip_abduct">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="hip_pitch">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="knee">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(arg controllers_config)</parameters>
    </plugin>
  </gazebo>

</robot>
